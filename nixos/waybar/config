{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["niri/workspaces", "cffi/niri-taskbar", "niri/window"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "cpu", "memory", "battery", "tray", "custom/logout", "custom/power"],

    "niri/workspaces": {},
    "cffi/niri-taskbar": {
        "module_path": "/run/current-system/sw/lib/libniri_taskbar.so"
    },
    "niri/window": {
        "max-length": 50
    },
    "clock": {
        "format": "{:%H:%M  %d/%m/%Y}"
    },
    "cpu": {
        "format": "{usage}% َ°چ›",
        "interval": 1,
        "min-length": 5,
        "format-alt-click": "click",
        "format-alt": "{icon0}{icon1}{icon2}{icon3} {usage:>2}% َ°چ›",
        "format-icons": ["â–پ", "â–‚", "â–ƒ", "â–„", "â–…", "â–†", "â–‡", "â–ˆ"]
    },
    "memory": {
        "interval": 10,
        "format": "{used:0.1f}G َ°¾†",
        "format-alt": "{percentage}% َ°¾†",
        "format-alt-click": "click",
        "tooltip": true,
        "tooltip-format": "{used:0.1f}GB / {total:0.1f}GB"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} َ°‚° {volume}%",
        "format-muted": "َ°–پ Muted",
        "format-icons": {
            "headphone": "َ°‹‹",
            "headset": "َ°‹ژ",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "scroll-step": 5.0,
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "tooltip-format": "{icon} {desc} | {volume}%"
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%)",
        "format-ethernet": "{ipaddr}",
        "format-disconnected": "Disconnected"
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": "َ±ک– {capacity}%",
        "format-full": "{icon} Full",
        "format-alt-click": "click",
        "format-alt": "{icon} {time}",
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "tooltip": true,
        "tooltip-format": "{timeTo} {power}w",
        "on-click": "~/.config/waybar/scripts/power-profile-cycle.sh"
    },
    "tray": {
        "spacing": 10
    },
    "custom/logout": {
        "format": "âڈڈ",
        "on-click": "bash -c 'zenity --question --title=\"Logout\" --text=\"Are you sure you want to log out?\" --ok-label=\"Logout\" --cancel-label=\"Cancel\" && niri msg action quit --skip-confirmation'",
        "tooltip-format": "Logout"
    },
    "custom/power": {
        "format": "âڈ»",
        "on-click": "bash -c 'zenity --question --title=\"Power Off\" --text=\"Are you sure you want to power off?\" --ok-label=\"Power Off\" --cancel-label=\"Cancel\" && systemctl poweroff'",
        "on-click-right": "bash -c 'zenity --question --title=\"Reboot\" --text=\"Are you sure you want to reboot?\" --ok-label=\"Reboot\" --cancel-label=\"Cancel\" && systemctl reboot'",
        "tooltip-format": "Left click: poweroff | Right click: reboot"
    }
}
